PORT=3000
JWT_SECRET=change-me-in-production
OPENROUTER_API_KEY=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
OPENROUTER_MODEL=openai/gpt-oss-20b:free
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Cognify
GEMINI_API_KEY=

# Supabase session pooler on port 5432.
# Backend loads `.env.local` first, then `.env`.
# Download the Supabase Root 2021 CA from Connect and save it as ./prisma/supabase-root-2021-ca.pem.
# Replace `cognify` with your own schema name if needed.
DATABASE_URL="postgresql://postgres.project-ref:your-password@aws-1-region.pooler.supabase.com:5432/postgres?sslmode=verify-full&sslrootcert=./prisma/supabase-root-2021-ca.pem&schema=cognify"

# Prisma CLI should use the same pooler route unless you switch to a direct Supabase connection.
DIRECT_URL="postgresql://postgres.project-ref:your-password@aws-1-region.pooler.supabase.com:5432/postgres?sslmode=verify-full&sslrootcert=./prisma/supabase-root-2021-ca.pem&schema=cognify"
